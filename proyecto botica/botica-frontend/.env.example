# ============================================================
# BOTICA CENTRAL — Frontend (.env.example)
# ============================================================
# Copia este archivo a .env (o .env.local) y rellena los valores.
# En Vite, SOLO las variables con prefijo VITE_ llegan al navegador.
# NUNCA pongas secretos del backend aquí (quedan expuestos en el bundle).
# En Vercel se configuran en Project Settings → Environment Variables.
# ============================================================

# URL base del backend (incluye /api). En producción: la URL de Render.
VITE_API_BASE=        # ej. https://tu-backend.onrender.com/api

# Clave PÚBLICA de MercadoPago (Public Key, no el Access Token).
VITE_MP_PUBLIC_KEY=

# Client ID de Google OAuth (login de clientes con Google).
VITE_GOOGLE_CLIENT_ID=

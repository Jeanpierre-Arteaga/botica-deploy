# ============================================================
# BOTICA CENTRAL — Backend (.env.example)
# ============================================================
# Copia este archivo a .env y rellena los valores reales.
# NUNCA subas el .env real (está en .gitignore).
# ============================================================

# Servidor
PORT=3000

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=botica_db
DB_USER=postgres
DB_PASSWORD=

# Auth
JWT_SECRET=

# CORS (orígenes permitidos, separados por coma)
CORS_ORIGINS=http://localhost:5173

# MercadoPago (sandbox)
MP_ACCESS_TOKEN=

# AWS S3 + CloudFront (imágenes de producto)
AWS_REGION=us-east-1
S3_BUCKET=botica-central-bucket
CLOUDFRONT_DOMAIN=d2gt6w64qg7rtz.cloudfront.net
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

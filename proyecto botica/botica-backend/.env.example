# ============================================================
# BOTICA CENTRAL — Backend (.env.example)
# ============================================================
# Copia este archivo a .env y rellena los valores reales.
# NUNCA subas el .env real (está en .gitignore).
#
# ⚠️  AVISO DE SEGURIDAD — LLAVES COMPROMETIDAS
# Versiones anteriores de este .env.example fueron commiteadas con credenciales
# REALES (siguen en el historial de git):
#   - AWS_ACCESS_KEY_ID = AKIAWHGFXODE6POOVC4Z  (+ su secret)
#   - GEMINI_API_KEY    = AQ.Ab8RN6Lj... (clave de Google AI Studio)
# Deben considerarse FILTRADAS y rotarse de inmediato:
#   1) AWS IAM → desactivar/eliminar esa access key y crear una nueva.
#   2) Google AI Studio → revocar la API key de Gemini y emitir otra.
# Aunque aquí queden en blanco, el valor antiguo persiste en el historial.
# ============================================================

# Entorno: development | production
NODE_ENV=development

# Servidor
PORT=3000

# PostgreSQL (local: localhost; producción: Supabase)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=botica_db
DB_USER=postgres
DB_PASSWORD=
# SSL de la BD. Déjalo SIN definir (o cualquier valor distinto de "false") para
# conectarte a Supabase/Postgres gestionado. Pon DB_SSL=false SOLO en local.
DB_SSL=false

# Auth
JWT_SECRET=

# CORS (orígenes permitidos, separados por coma). En producción: la URL de Vercel.
CORS_ORIGINS=http://localhost:5173
# URL pública del frontend (enlaces en correos: recuperación de contraseña, etc.)
FRONTEND_URL=http://localhost:5173

# MercadoPago (sandbox)
MP_ACCESS_TOKEN=

# AWS S3 + CloudFront (imágenes de producto)
# ⚠️ Las llaves de abajo fueron filtradas (ver aviso arriba) — ROTAR antes de usar.
AWS_REGION=us-east-1
S3_BUCKET=
CLOUDFRONT_DOMAIN=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Google Gemini (lectura de recetas médicas con visión)
# Crea una API key gratuita en Google AI Studio: https://aistudio.google.com/apikey
# NUNCA subas el valor real (el .env está en .gitignore). La llamada se hace
# SOLO desde el backend; la clave nunca llega al navegador.
# ⚠️ La clave anterior fue filtrada (ver aviso arriba) — ROTAR antes de usar.
GEMINI_API_KEY=
# Opcional: nombre del modelo de visión. Por defecto gemini-2.5-flash.
GEMINI_MODEL=gemini-2.5-flash

# Google OAuth (login de clientes con Google). Client ID del proyecto de Google.
GOOGLE_CLIENT_ID=

# ============================================================
# SMTP (envío de correos: recuperación de contraseña y código 2FA)
# ============================================================
# Si lo dejas vacío, el backend NO envía correo: loguea el enlace/código en
# consola (modo desarrollo). Ejemplo con Gmail + "App Password" de 16 dígitos:
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
# true = puerto 465 (SSL); false = 587 (STARTTLS).
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Boticas Central <no-reply@boticascentral.pe>

# ============================================================
# Verificación en dos pasos (2FA por correo) — admin y staff
# ============================================================
# TWOFA_ENABLED: true (default) pide un código de 6 dígitos al correo del
#   usuario. Ponlo en false para omitir el 2FA por completo (login normal).
TWOFA_ENABLED=true
# TWOFA_DEV_CODE: código de respaldo SOLO para desarrollo/demo. Si está definido
#   (p. ej. 123456), además del código enviado por correo ESTE valor SIEMPRE es
#   válido. Déjalo VACÍO en producción.
TWOFA_DEV_CODE=

# ============================================================
# BOTICA CENTRAL — Backend (.env.example)
# ============================================================
# Copia este archivo a .env y rellena los valores reales.
# NUNCA subas el .env real (está en .gitignore).
#
# ⚠️  AVISO DE SEGURIDAD — LLAVES COMPROMETIDAS
# Versiones anteriores de este .env.example fueron commiteadas con credenciales
# REALES (siguen en el historial de git):
#   - AWS_ACCESS_KEY_ID = AKIAWHGFXODE6POOVC4Z  (+ su secret)
#   - GEMINI_API_KEY    = AQ.Ab8RN6Lj... (clave de Google AI Studio)
# Deben considerarse FILTRADAS y rotarse de inmediato:
#   1) AWS IAM → desactivar/eliminar esa access key y crear una nueva.
#   2) Google AI Studio → revocar la API key de Gemini y emitir otra.
# Aunque aquí queden en blanco, el valor antiguo persiste en el historial.
# ============================================================

# Entorno: development | production
NODE_ENV=development

# Servidor
PORT=3000

# PostgreSQL (local: localhost; producción: Supabase)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=botica_db
DB_USER=postgres
DB_PASSWORD=
# SSL de la BD. Déjalo SIN definir (o cualquier valor distinto de "false") para
# conectarte a Supabase/Postgres gestionado. Pon DB_SSL=false SOLO en local.
DB_SSL=false

# Auth
JWT_SECRET=

# CORS (orígenes permitidos, separados por coma). En producción: la URL de Vercel.
CORS_ORIGINS=http://localhost:5173
# URL pública del frontend (enlaces en correos: recuperación de contraseña, etc.)
FRONTEND_URL=http://localhost:5173

# MercadoPago (sandbox)
MP_ACCESS_TOKEN=

# AWS S3 + CloudFront (imágenes de producto)
# ⚠️ Las llaves de abajo fueron filtradas (ver aviso arriba) — ROTAR antes de usar.
AWS_REGION=us-east-1
S3_BUCKET=
CLOUDFRONT_DOMAIN=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Google Gemini (lectura de recetas médicas con visión)
# Crea una API key gratuita en Google AI Studio: https://aistudio.google.com/apikey
# NUNCA subas el valor real (el .env está en .gitignore). La llamada se hace
# SOLO desde el backend; la clave nunca llega al navegador.
# ⚠️ La clave anterior fue filtrada (ver aviso arriba) — ROTAR antes de usar.
GEMINI_API_KEY=
# Opcional: nombre del modelo de visión. Por defecto gemini-2.5-flash.
GEMINI_MODEL=gemini-2.5-flash

# Google OAuth (login de clientes con Google). Client ID del proyecto de Google.
GOOGLE_CLIENT_ID=

# ============================================================
# CORREO (Resend) — recuperación de contraseña y código 2FA
# ============================================================
# El backend envía correo por la API HTTP de Resend (https://resend.com), NO por
# SMTP. Motivo: Render BLOQUEA el SMTP saliente, así que nodemailer/Gmail nunca
# entregaba. La API HTTP de Resend sí funciona en Render.
#
# 1) Crea una cuenta en resend.com y genera una API key.
RESEND_API_KEY=
# 2) Remitente. Para EMPEZAR usa el remitente de prueba de Resend (no requiere
#    verificar dominio). Puedes anteponer un nombre visible:
#       MAIL_FROM=Boticas Central <onboarding@resend.dev>
#    Si lo dejas vacío, el código usa 'onboarding@resend.dev'.
MAIL_FROM=onboarding@resend.dev
# 3) Timeout del envío en ms (AbortController). 8000 por defecto. Si Resend
#    tarda/falla, el correo aborta rápido y NUNCA cuelga la respuesta (va en 2º
#    plano). Cae a SMTP_TIMEOUT_MS si MAIL_TIMEOUT_MS no está definido.
MAIL_TIMEOUT_MS=8000
#
# ⚠️  NOTA DE PRODUCCIÓN (remitente de prueba):
#   Con MAIL_FROM=onboarding@resend.dev, Resend SOLO entrega al correo de la
#   cuenta Resend (el tuyo). Para enviar a CUALQUIER destinatario:
#     a) Verifica un dominio propio en Resend (DNS: SPF/DKIM).
#     b) Cambia SOLO MAIL_FROM a ese dominio, p. ej.:
#          MAIL_FROM=Boticas Central <no-reply@tudominio.com>
#   No hay que tocar código: el remitente sale siempre de MAIL_FROM.
#
# Si RESEND_API_KEY queda vacío, el backend NO envía: loguea el enlace/código en
# consola (modo desarrollo), igual que antes.
#
# (Legacy) Las variables SMTP_* ya NO se usan (se migró a Resend). Puedes
# borrarlas. SMTP_TIMEOUT_MS solo se conserva como fallback de MAIL_TIMEOUT_MS.

# ============================================================
# Verificación en dos pasos (2FA por correo) — admin, staff y cliente
# ============================================================
# TWOFA_ENABLED: true (default) pide un código de 6 dígitos al correo del
#   usuario de PERSONAL/ADMIN. Ponlo en false para omitir el 2FA de staff.
TWOFA_ENABLED=true
# TWOFA_CUSTOMER_ENABLED: 2FA del CLIENTE (login con correo+contraseña). Si NO se
#   define (o vacío) sigue a TWOFA_ENABLED. Ponlo en false para desactivar SOLO
#   el del cliente sin tocar el de staff (o true para forzarlo). El login con
#   Google del cliente NUNCA pide 2FA (Google ya verificó el correo).
TWOFA_CUSTOMER_ENABLED=
# TWOFA_DEV_CODE: código de respaldo SOLO para desarrollo/demo (sirve para staff
#   Y cliente). Si está definido (p. ej. 123456), además del código enviado por
#   correo ESTE valor SIEMPRE es válido. Déjalo VACÍO en producción.
TWOFA_DEV_CODE=

# ============================================================
# Google OAuth — timeout de verificación del token (login con Google)
# ============================================================
# Timeout en ms de las llamadas del backend a Google (tokeninfo/userinfo) al
# verificar el access_token del cliente. 8000 por defecto. Evita que una llamada
# lenta a Google cuelgue la respuesta del login con Google.
GOOGLE_TIMEOUT_MS=8000

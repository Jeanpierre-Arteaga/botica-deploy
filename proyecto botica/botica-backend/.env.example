# ============================================================
# BOTICA CENTRAL — Backend (.env.example)
# ============================================================
# Copia este archivo a .env y rellena los valores reales.
# NUNCA subas el .env real (está en .gitignore).
# ============================================================

# Servidor
PORT=3000

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=botica_db
DB_USER=postgres
DB_PASSWORD=

# Auth
JWT_SECRET=

# CORS (orígenes permitidos, separados por coma)
CORS_ORIGINS=http://localhost:5173

# MercadoPago (sandbox)
MP_ACCESS_TOKEN=

# AWS S3 + CloudFront (imágenes de producto)
AWS_REGION=us-east-1
S3_BUCKET=botica-central-bucket
CLOUDFRONT_DOMAIN=d2gt6w64qg7rtz.cloudfront.net
AWS_ACCESS_KEY_ID=AKIAWHGFXODE6POOVC4Z
AWS_SECRET_ACCESS_KEY=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

# Google Gemini (lectura de recetas médicas con visión)
# Crea una API key gratuita en Google AI Studio: https://aistudio.google.com/apikey
# NUNCA subas el valor real (el .env está en .gitignore). La llamada se hace
# SOLO desde el backend; la clave nunca llega al navegador.
GEMINI_API_KEY=AQ.Ab8RN6LjD0Ub5UZpqS7QjI6BHgYHOriJrpt6KOifxwtEZiL9pQ
# Opcional: nombre del modelo de visión. Por defecto gemini-2.5-flash.
GEMINI_MODEL=gemini-2.5-flash

# ============================================================
# SMTP (envío de correos: recuperación de contraseña y código 2FA)
# ============================================================
# Si lo dejas vacío, el backend NO envía correo: loguea el enlace/código en
# consola (modo desarrollo). Ejemplo con Gmail + "App Password" de 16 dígitos:
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Boticas Central <no-reply@boticascentral.pe>

# ============================================================
# Verificación en dos pasos (2FA por correo) — admin y staff
# ============================================================
# TWOFA_ENABLED: true (default) pide un código de 6 dígitos al correo del
#   usuario. Ponlo en false para omitir el 2FA por completo (login normal).
TWOFA_ENABLED=true
# TWOFA_DEV_CODE: código de respaldo SOLO para desarrollo/demo. Si está definido
#   (p. ej. 123456), además del código enviado por correo ESTE valor SIEMPRE es
#   válido. Déjalo VACÍO en producción.
TWOFA_DEV_CODE=
